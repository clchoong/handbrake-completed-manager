<Window x:Class="HandBrakeCompletedManager.App.BulkReplacementProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk source replacement"
        Width="820"
        Height="640"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26,20" Background="{StaticResource NavyBrush}">
            <StackPanel>
                <TextBlock FontSize="23" FontWeight="SemiBold" Foreground="White" Text="Replacing selected sources" />
                <TextBlock Margin="0,5,0,0" Foreground="#AEB9CA" Text="Overall progress and every selected file remain visible until the batch finishes" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="26,22,26,12" Padding="18,16" Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Total progress" />
                    <TextBlock x:Name="OverallCountText" HorizontalAlignment="Right" FontSize="16" FontWeight="SemiBold" Text="0/0" />
                </Grid>
                <ProgressBar x:Name="OverallProgressBar" Height="16" Margin="0,13,0,0" Minimum="0" Maximum="100" />
                <Grid Margin="0,8,0,0">
                    <TextBlock x:Name="OverallStatusText" Foreground="{StaticResource InkMutedBrush}" Text="Waiting to start" />
                    <TextBlock x:Name="OverallPercentageText" HorizontalAlignment="Right" FontWeight="SemiBold" Text="0%" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="26,0,26,18" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,13" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Number}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{Binding StatusBrush}" Text="{Binding Percentage, StringFormat={}{0:0}%}" />
                                    </Grid>
                                    <ProgressBar Height="10" Margin="36,10,0,0" Minimum="0" Maximum="100" Value="{Binding Percentage}" />
                                    <TextBlock Margin="36,7,0,0" Foreground="{Binding StatusBrush}" Text="{Binding Status}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="CancelCurrentButton" MinWidth="142" Margin="0,0,8,0" IsEnabled="False" Click="CancelCurrentButton_Click" Content="Cancel current &amp; stop" />
                <Button x:Name="StopButton" MinWidth="130" Margin="0,0,8,0" Click="StopButton_Click" Content="Stop after current" />
                <Button x:Name="CloseButton" MinWidth="100" IsEnabled="False" Click="CloseButton_Click" Content="Close" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
