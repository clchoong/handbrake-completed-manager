<Window x:Class="HandBrakeCompletedManager.App.RecoveryOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replacement recovery"
        Width="1040"
        Height="580"
        MinWidth="780"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="26,20" Background="{StaticResource NavyBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="Replacement recovery" />
                    <TextBlock Margin="0,4,0,0" Foreground="#AEB9CA" Text="Continue safely from the last verified transaction checkpoint" />
                </StackPanel>
                <Border Grid.Column="1" Padding="12,7" VerticalAlignment="Center" Background="#263650" CornerRadius="18">
                    <TextBlock FontWeight="SemiBold" Foreground="White" Text="Read-only overview" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="26,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Margin="0,0,0,14"
                    Padding="15"
                    Background="{StaticResource SuccessSoftBrush}"
                    BorderBrush="#B8E4D4"
                    BorderThickness="1"
                    CornerRadius="11">
                <TextBlock Foreground="#155F49"
                           TextWrapping="Wrap"
                           Text="No action runs automatically. Select a transaction and open its matching record to expose only the control permitted by the persisted checkpoint." />
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid x:Name="RecoveryGrid"
                          ItemsSource="{Binding}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="RecoveryGrid_SelectionChanged"
                          MouseDoubleClick="RecoveryGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="UPDATED" Binding="{Binding UpdatedUtc, StringFormat={}{0:g}}" Width="145" />
                        <DataGridTextColumn Header="SOURCE" Binding="{Binding SourcePath}" Width="2*" MinWidth="220" />
                        <DataGridTextColumn Header="NEXT SAFE ACTION" Binding="{Binding Action}" Width="180" />
                        <DataGridTextColumn Header="ASSESSMENT" Binding="{Binding Summary}" Width="3*" MinWidth="280" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="96" Margin="0,0,8,0" IsCancel="True" Click="CloseButton_Click" Content="Close" />
                <Button x:Name="OpenRecordButton"
                        MinWidth="126"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="False"
                        IsDefault="True"
                        Click="OpenRecordButton_Click"
                        Content="Open record" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
