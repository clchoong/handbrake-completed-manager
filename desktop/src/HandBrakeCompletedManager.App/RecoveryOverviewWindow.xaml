<Window x:Class="HandBrakeCompletedManager.App.RecoveryOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replacement recovery review"
        Width="900"
        Height="500"
        MinWidth="700"
        MinHeight="360"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,14">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Replacement recovery review" />
            <TextBlock Margin="0,5,0,0"
                       Text="Read-only restart assessment. Open the matching completed record and choose Review replacement to perform an available recovery action."
                       TextWrapping="Wrap" />
        </StackPanel>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedUtc, StringFormat={}{0:g}}" Width="145" />
                <DataGridTextColumn Header="Source" Binding="{Binding SourcePath}" Width="2*" MinWidth="220" />
                <DataGridTextColumn Header="Suggested action" Binding="{Binding Action}" Width="170" />
                <DataGridTextColumn Header="Assessment" Binding="{Binding Summary}" Width="3*" MinWidth="280" />
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Row="2"
                Width="90"
                Height="32"
                Margin="0,14,0,0"
                HorizontalAlignment="Right"
                IsDefault="True"
                Click="CloseButton_Click"
                Content="Close" />
    </Grid>
</Window>
