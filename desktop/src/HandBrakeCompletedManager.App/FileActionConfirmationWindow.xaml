<Window x:Class="HandBrakeCompletedManager.App.FileActionConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm action"
        Width="760"
        Height="430"
        MinWidth="640"
        MinHeight="390"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26,20" Background="{StaticResource NavyBrush}">
            <StackPanel>
                <TextBlock x:Name="HeadingText" FontSize="23" FontWeight="SemiBold" Foreground="White" />
                <TextBlock x:Name="DescriptionText"
                           Margin="0,5,0,0"
                           Foreground="#AEB9CA"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="26,22">
            <Border Margin="0,0,0,12" Padding="16,13" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="SOURCE" />
                    <TextBox x:Name="SourcePathTextBox" Margin="0,7,0,0" IsReadOnly="True" />
                </StackPanel>
            </Border>
            <Border Padding="16,13" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="OUTPUT" />
                    <TextBox x:Name="OutputPathTextBox" Margin="0,7,0,0" IsReadOnly="True" />
                </StackPanel>
            </Border>
            <TextBlock x:Name="SafetyText"
                       Margin="2,14,2,0"
                       Foreground="{StaticResource InkMutedBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="2" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="100" Margin="0,0,8,0" IsCancel="True" Content="Cancel" />
                <Button x:Name="ConfirmButton"
                        MinWidth="160"
                        Style="{StaticResource DangerButtonStyle}"
                        IsDefault="True"
                        Click="ConfirmButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
