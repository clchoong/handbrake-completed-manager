<Window x:Class="HandBrakeCompletedManager.App.BulkOperationProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk operation"
        Width="660"
        Height="350"
        MinWidth="580"
        MinHeight="330"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Padding="26,20" Background="{StaticResource NavyBrush}">
            <StackPanel>
                <TextBlock x:Name="HeadingText" FontSize="23" FontWeight="SemiBold" Foreground="White" />
                <TextBlock x:Name="SubtitleText" Margin="0,5,0,0" Foreground="#AEB9CA" />
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Margin="28,25">
            <TextBlock x:Name="CurrentItemText" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <ProgressBar x:Name="ProgressBar" Height="16" Margin="0,20,0,0" Minimum="0" Maximum="100" />
            <Grid Margin="0,9,0,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource InkMutedBrush}" />
                <TextBlock x:Name="PercentageText" HorizontalAlignment="Right" FontWeight="SemiBold" />
            </Grid>
        </StackPanel>
        <Border Grid.Row="2" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <Button x:Name="CloseButton" MinWidth="100" HorizontalAlignment="Right" IsEnabled="False" Click="CloseButton_Click" Content="Close" />
        </Border>
    </Grid>
</Window>
