<Window x:Class="HandBrakeCompletedManager.App.ReplacementReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replacement safety review"
        Width="760"
        Height="610"
        MinWidth="640"
        MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Replacement safety review" />
            <Border Margin="0,10,0,14"
                    Padding="10"
                    Background="#FFF7DF"
                    BorderBrush="#E8C56D"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock FontWeight="SemiBold"
                           Text="Review only — this window cannot copy, move, rename, or delete files." />
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="125" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontWeight="SemiBold" Text="Source" />
            <TextBox x:Name="SourcePathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="Converted" />
            <TextBox x:Name="DestinationPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="Planned final" />
            <TextBox x:Name="FinalPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="3" FontWeight="SemiBold" Text="Temporary copy" />
            <TextBox x:Name="TemporaryPathTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="4" FontWeight="SemiBold" Text="Original backup" />
            <TextBox x:Name="BackupPathTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="5" FontWeight="SemiBold" Text="Current sizes" />
            <TextBlock x:Name="SizesText" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="2"
                Padding="12"
                Background="#F8FAFB"
                BorderBrush="#DDE2E7"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel>
                <TextBlock x:Name="OutcomeText"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,8"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <ListBox x:Name="IssuesList" BorderThickness="0" />
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,16,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="90" Height="32" IsDefault="True" Click="CloseButton_Click" Content="Close" />
        </StackPanel>
    </Grid>
</Window>
