<Window x:Class="HandBrakeCompletedManager.App.ReplacementReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safe replacement review"
        Width="1040"
        Height="820"
        MinWidth="820"
        MinHeight="660"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="26,20" Background="{StaticResource NavyBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="Safe replacement review" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#AEB9CA"
                               Text="Review every path before authorizing the verified replacement workflow" />
                </StackPanel>
                <Border Grid.Column="1"
                        Padding="12,7"
                        VerticalAlignment="Center"
                        Background="#263650"
                        BorderBrush="#3A4A63"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center" Fill="#5AD2A8" />
                        <TextBlock FontWeight="SemiBold" Foreground="White" Text="Recoverable workflow" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="26,22,26,18">
                <Border Margin="0,0,0,16"
                        Padding="16"
                        Background="{StaticResource WarningSoftBrush}"
                        BorderBrush="#F1D49B"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="34" Height="34" Margin="0,0,12,0" Background="#FFE2AD" CornerRadius="9">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"
                                       Text="!" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" Text="Protected file operation" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="#77511F"
                                       TextWrapping="Wrap"
                                       Text="One confirmation runs every verification in order. The original source moves only to the Windows Recycle Bin—never permanent deletion. Detailed controls below are reserved for recovery." />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,0,0,16" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowStyle}" Text="REVIEWED FILE PLAN" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" FontWeight="SemiBold" VerticalAlignment="Center" Text="Original source" />
                            <TextBox x:Name="SourcePathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" AutomationProperties.Name="Original source path" IsReadOnly="True" />
                            <TextBlock Grid.Row="0" Grid.Column="3" FontWeight="SemiBold" VerticalAlignment="Center" Text="HandBrake output" />
                            <TextBox x:Name="DestinationPathTextBox" Grid.Row="0" Grid.Column="4" Margin="0,0,0,8" AutomationProperties.Name="HandBrake output path" IsReadOnly="True" />
                            <TextBlock Grid.Row="1" FontWeight="SemiBold" VerticalAlignment="Center" Text="Planned final" />
                            <TextBox x:Name="FinalPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" AutomationProperties.Name="Planned final path" IsReadOnly="True" />
                            <TextBlock Grid.Row="1" Grid.Column="3" FontWeight="SemiBold" VerticalAlignment="Center" Text="Original backup" />
                            <TextBox x:Name="BackupPathTextBox" Grid.Row="1" Grid.Column="4" Margin="0,0,0,8" AutomationProperties.Name="Original backup path" IsReadOnly="True" />
                            <TextBlock Grid.Row="2" FontWeight="SemiBold" VerticalAlignment="Center" Text="Temporary copy" />
                            <TextBox x:Name="TemporaryPathTextBox" Grid.Row="2" Grid.Column="1" AutomationProperties.Name="Temporary copy path" IsReadOnly="True" />
                            <TextBlock Grid.Row="2" Grid.Column="3" FontWeight="SemiBold" VerticalAlignment="Center" Text="Current sizes" />
                            <TextBlock x:Name="SizesText" Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource InkMutedBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Padding="20"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="#F5C6B4"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Style="{StaticResource EyebrowStyle}" Foreground="#B4411B" Text="RECOMMENDED ACTION" />
                            <TextBlock Margin="0,5,0,0" FontSize="20" FontWeight="SemiBold" Text="Replace the source safely in one workflow" />
                            <TextBlock Margin="0,5,0,0"
                                       Foreground="#76432E"
                                       TextWrapping="Wrap"
                                       Text="Creates and verifies both protective copies, promotes without overwriting, moves the original to the Recycle Bin, and records completion atomically." />
                        </StackPanel>
                        <Button x:Name="SafeReplaceButton"
                                Grid.Column="1"
                                MinWidth="210"
                                MinHeight="48"
                                VerticalAlignment="Center"
                                Style="{StaticResource PrimaryButtonStyle}"
                                IsEnabled="False"
                                Click="SafeReplaceButton_Click"
                                Content="Replace source safely" />
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowStyle}" Text="1 · VERIFIED OUTPUT COPY" />
                            <TextBlock Margin="0,7,0,11" Style="{StaticResource MutedTextStyle}" Text="Streams the HandBrake output into the source location, then verifies size and SHA-256." />
                            <ProgressBar x:Name="CopyProgressBar" Minimum="0" Maximum="100" Value="0" />
                            <TextBlock x:Name="CopyStatusText" Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}" Text="Not started." />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowStyle}" Text="2 · VERIFIED ORIGINAL BACKUP" />
                            <TextBlock Margin="0,7,0,11" Style="{StaticResource MutedTextStyle}" Text="Protects the original source in a dedicated backup before any source retirement." />
                            <ProgressBar x:Name="BackupProgressBar" Minimum="0" Maximum="100" Value="0" />
                            <TextBlock x:Name="BackupStatusText" Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}" Text="Waiting for a verified temporary copy." />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,0,0,16" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowStyle}" Text="SAFETY REVIEW" />
                        <TextBlock x:Name="OutcomeText" Margin="0,7,0,8" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <ListBox x:Name="IssuesList" MaxHeight="130" />
                        <TextBlock x:Name="RecoveryStatusText"
                                   Margin="0,9,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Expander IsExpanded="False">
                    <Expander.Header>
                        <Border Padding="18,14" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Advanced recovery controls" />
                                    <TextBlock Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="Continue an interrupted checkpoint or inspect each internal stage manually" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Text="Show controls" />
                            </Grid>
                        </Border>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowStyle}" Text="COPY AND BACKUP RECOVERY" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="PrepareCopyButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" Click="PrepareCopyButton_Click" Content="Create temporary copy" />
                                <Button x:Name="CancelCopyButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="CancelCopyButton_Click" Content="Cancel copy" />
                                <Button x:Name="DiscardTemporaryButton" Margin="0,0,8,8" Style="{StaticResource DangerButtonStyle}" IsEnabled="False" Click="DiscardTemporaryButton_Click" Content="Discard temporary" />
                                <Button x:Name="CreateBackupButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="CreateBackupButton_Click" Content="Create original backup" />
                                <Button x:Name="CancelBackupButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="CancelBackupButton_Click" Content="Cancel backup" />
                                <Button x:Name="DiscardBackupButton" Margin="0,0,0,8" Style="{StaticResource DangerButtonStyle}" IsEnabled="False" Click="DiscardBackupButton_Click" Content="Discard backup" />
                            </WrapPanel>

                            <Border Margin="0,10" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" />
                            <TextBlock Style="{StaticResource EyebrowStyle}" Text="FORWARD COMPLETION" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="CheckFinalizationButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="CheckFinalizationButton_Click" Content="Check readiness" />
                                <Button x:Name="PromoteFinalButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="PromoteFinalButton_Click" Content="Promote verified copy" />
                                <Button x:Name="RecycleSourceButton" Margin="0,0,8,8" Style="{StaticResource DangerButtonStyle}" IsEnabled="False" Click="RecycleSourceButton_Click" Content="Recycle original source" />
                                <Button x:Name="CompleteFinalizationButton" Margin="0,0,0,8" Style="{StaticResource DarkButtonStyle}" IsEnabled="False" Click="CompleteFinalizationButton_Click" Content="Complete finalisation" />
                            </WrapPanel>

                            <Border Margin="0,10" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" />
                            <TextBlock Style="{StaticResource EyebrowStyle}" Text="SOURCE-FIRST UNDO" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="BeginUndoButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="BeginUndoButton_Click" Content="Prepare undo" />
                                <Button x:Name="RestoreSourceButton" Margin="0,0,8,8" Style="{StaticResource CompactButtonStyle}" IsEnabled="False" Click="RestoreSourceButton_Click" Content="Restore original source" />
                                <Button x:Name="RecycleFinalButton" Margin="0,0,8,8" Style="{StaticResource DangerButtonStyle}" IsEnabled="False" Click="RecycleFinalButton_Click" Content="Recycle promoted final" />
                                <Button x:Name="CompleteUndoButton" Margin="0,0,0,8" Style="{StaticResource DarkButtonStyle}" IsEnabled="False" Click="CompleteUndoButton_Click" Content="Complete undo" />
                            </WrapPanel>

                            <Border Margin="0,10,0,0" Padding="12" Background="{StaticResource SurfaceMutedBrush}" CornerRadius="9">
                                <TextBlock x:Name="FinalizationStatusText" Text="Finalisation remains disabled." TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="96" IsCancel="True" Click="CloseButton_Click" Content="Close" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
