<Window x:Class="HandBrakeCompletedManager.App.ReplacementReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replacement safety review"
        Width="760"
        Height="700"
        MinWidth="640"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Replacement safety review" />
            <Border Margin="0,10,0,14"
                    Padding="10"
                    Background="#FFF7DF"
                    BorderBrush="#E8C56D"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock FontWeight="SemiBold"
                           Text="Safety boundary — this window can create and verify separate temporary and original-backup copies. It cannot replace or delete the source."
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="125" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontWeight="SemiBold" Text="Source" />
            <TextBox x:Name="SourcePathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="Converted" />
            <TextBox x:Name="DestinationPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="Planned final" />
            <TextBox x:Name="FinalPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="3" FontWeight="SemiBold" Text="Temporary copy" />
            <TextBox x:Name="TemporaryPathTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="4" FontWeight="SemiBold" Text="Original backup" />
            <TextBox x:Name="BackupPathTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" IsReadOnly="True" />
            <TextBlock Grid.Row="5" FontWeight="SemiBold" Text="Current sizes" />
            <TextBlock x:Name="SizesText" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="2"
                Margin="0,0,0,14"
                Padding="12"
                Background="#EFF7FF"
                BorderBrush="#9BC2E6"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Temporary-copy preparation" />
                <TextBlock Margin="0,4,0,10"
                           Text="Creates a new .hbcm-copying file, records progress, and verifies size and SHA-256. The source and converted files remain unchanged."
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="CopyProgressBar" Height="18" Minimum="0" Maximum="100" Value="0" />
                <TextBlock x:Name="CopyStatusText" Margin="0,5,0,0" Text="Not started." TextWrapping="Wrap" />
                <TextBlock x:Name="RecoveryStatusText"
                           Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Foreground="#7A4B00"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
                <Border Margin="0,12,0,10" BorderBrush="#9BC2E6" BorderThickness="0,1,0,0" />
                <TextBlock FontWeight="SemiBold" Text="Original backup preparation" />
                <TextBlock Margin="0,4,0,8"
                           Text="After the temporary converted copy is verified, creates and verifies a separate copy of the original source. The source is not moved or deleted."
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="BackupProgressBar" Height="18" Minimum="0" Maximum="100" Value="0" />
                <TextBlock x:Name="BackupStatusText" Margin="0,5,0,8" Text="Waiting for a verified temporary copy." TextWrapping="Wrap" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="CreateBackupButton"
                            Width="165"
                            Height="30"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="CreateBackupButton_Click"
                            Content="Create original backup" />
                    <Button x:Name="CancelBackupButton"
                            Width="105"
                            Height="30"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="CancelBackupButton_Click"
                            Content="Cancel backup" />
                    <Button x:Name="DiscardBackupButton"
                            Width="145"
                            Height="30"
                            IsEnabled="False"
                            Click="DiscardBackupButton_Click"
                            Content="Discard backup file" />
                </StackPanel>
                <Border Margin="0,12,0,8" BorderBrush="#9BC2E6" BorderThickness="0,1,0,0" />
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="CheckFinalizationButton"
                                Width="180"
                                Height="30"
                                Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="CheckFinalizationButton_Click"
                                Content="Check finalisation readiness" />
                        <Button x:Name="PromoteFinalButton"
                                Width="165"
                                Height="30"
                                IsEnabled="False"
                                Click="PromoteFinalButton_Click"
                                Content="Promote verified copy" />
                    </StackPanel>
                    <TextBlock x:Name="FinalizationStatusText"
                               Margin="0,4,10,0"
                               Text="Finalisation remains disabled."
                               TextWrapping="Wrap" />
                </DockPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Padding="12"
                Background="#F8FAFB"
                BorderBrush="#DDE2E7"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel>
                <TextBlock x:Name="OutcomeText"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,8"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <ListBox x:Name="IssuesList" BorderThickness="0" />
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,16,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button x:Name="PrepareCopyButton"
                    Width="170"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="PrepareCopyButton_Click"
                    Content="Create temporary copy" />
            <Button x:Name="CancelCopyButton"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="CancelCopyButton_Click"
                    Content="Cancel copy" />
            <Button x:Name="DiscardTemporaryButton"
                    Width="155"
                    Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="DiscardTemporaryButton_Click"
                    Content="Discard temporary file" />
            <Button Width="90" Height="32" IsCancel="True" Click="CloseButton_Click" Content="Close" />
        </StackPanel>
    </Grid>
</Window>
