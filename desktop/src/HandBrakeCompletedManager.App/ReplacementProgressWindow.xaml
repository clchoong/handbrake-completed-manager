<Window x:Class="HandBrakeCompletedManager.App.ReplacementProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replacing source"
        Width="720"
        Height="430"
        MinWidth="620"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26,20" Background="{StaticResource NavyBrush}">
            <StackPanel>
                <TextBlock FontSize="23" FontWeight="SemiBold" Foreground="White" Text="Replacing the source file" />
                <TextBlock Margin="0,5,0,0" Foreground="#AEB9CA" Text="The direct file transfer runs automatically while progress remains visible" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="28,26">
            <TextBlock x:Name="FileNameText" FontSize="19" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="StageText"
                       Margin="0,9,0,0"
                       Foreground="{StaticResource InkMutedBrush}"
                       TextWrapping="Wrap" />
            <ProgressBar x:Name="OverallProgressBar"
                         Height="16"
                         Margin="0,22,0,0"
                         Minimum="0"
                         Maximum="100" />
            <Grid Margin="0,9,0,0">
                <TextBlock x:Name="ProgressText" Foreground="{StaticResource InkMutedBrush}" />
                <TextBlock x:Name="PercentageText" HorizontalAlignment="Right" FontWeight="SemiBold" />
            </Grid>
            <Border Margin="0,22,0,0"
                    Padding="14,12"
                    Background="{StaticResource SurfaceMutedBrush}"
                    CornerRadius="9">
                <TextBlock x:Name="OutcomeText"
                           Text="Keep this window open while the replacement is running."
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        IsEnabled="False"
                        Click="CancelButton_Click"
                        Content="Cancel" />
                <Button x:Name="CloseButton"
                        MinWidth="100"
                        IsEnabled="False"
                        Click="CloseButton_Click"
                        Content="Close" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
