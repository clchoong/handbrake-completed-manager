<Window x:Class="HandBrakeCompletedManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HandBrake Completed Manager"
        Height="860"
        Width="1240"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="HandBrake Completed Manager"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#18212B" />
                <TextBlock Text="Permanent completed-encode history"
                           Margin="0,4,0,0"
                           FontSize="14"
                           Foreground="#596573" />
            </StackPanel>
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Width="100"
                    Height="36"
                    VerticalAlignment="Center"
                    Click="RefreshButton_Click"
                    Content="Refresh" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,18"
                Padding="18"
                Background="White"
                BorderBrush="#DDE2E7"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Completed encodes" Foreground="#697583" />
                    <TextBlock x:Name="CompletedCountText" Text="0" FontSize="24" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Original size" Foreground="#697583" />
                    <TextBlock x:Name="OriginalSizeText" Text="0 B" FontSize="24" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Converted size" Foreground="#697583" />
                    <TextBlock x:Name="ConvertedSizeText" Text="0 B" FontSize="24" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Storage saved" Foreground="#697583" />
                    <TextBlock x:Name="SpaceSavedText" Text="0 B" FontSize="24" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,18"
                Padding="18"
                Background="White"
                BorderBrush="#DDE2E7"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Width="170" VerticalAlignment="Center">
                    <TextBlock Text="HandBrake connection" FontWeight="SemiBold" />
                    <TextBlock x:Name="ConnectionStatusText"
                               Margin="0,3,12,0"
                               Foreground="#697583"
                               Text="Not checked" />
                </StackPanel>
                <ComboBox x:Name="InstallationComboBox"
                          Grid.Column="1"
                          Margin="0,0,12,0"
                          MinHeight="34"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding DetectedInstallations}"
                          DisplayMemberPath="DisplayLabel"
                          SelectionChanged="InstallationComboBox_SelectionChanged" />
                <Button x:Name="FindHandBrakeButton"
                        Grid.Column="2"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="FindHandBrakeButton_Click"
                        Content="Find HandBrake" />
                <Button x:Name="BrowseHandBrakeButton"
                        Grid.Column="3"
                        Width="80"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="BrowseHandBrakeButton_Click"
                        Content="Browse" />
                <Button x:Name="TestConnectionButton"
                        Grid.Column="4"
                        Width="110"
                        Height="34"
                        Click="TestConnectionButton_Click"
                        Content="Test Pipeline"
                        IsEnabled="False" />
            </Grid>
        </Border>

        <Expander Grid.Row="3"
                  Margin="0,0,0,18"
                  Padding="18,12"
                  Background="White"
                  BorderBrush="#DDE2E7"
                  BorderThickness="1"
                  IsExpanded="False">
            <Expander.Header>
                <StackPanel>
                    <TextBlock Text="Configure completed-encode capture"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ReceiverStatusText"
                               Margin="0,3,0,0"
                               Foreground="#697583"
                               Text="Checking receiver..." />
                </StackPanel>
            </Expander.Header>
            <Grid Margin="0,12,0,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="115" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="3"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           Text="In HandBrake, open Tools > Preferences > When Done. Under Encode Completed, enable Send File To, then use the executable and arguments below." />

                <TextBlock Grid.Row="1"
                           VerticalAlignment="Center"
                           Text="Executable" />
                <TextBox x:Name="ReceiverPathTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,8,8"
                         Padding="7,5"
                         IsReadOnly="True" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Height="30"
                        Margin="0,0,0,8"
                        Click="CopyReceiverPathButton_Click"
                        Content="Copy path" />

                <TextBlock Grid.Row="2"
                           VerticalAlignment="Center"
                           Text="Arguments" />
                <TextBox x:Name="ReceiverArgumentsTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,8,0"
                         Padding="7,5"
                         IsReadOnly="True" />
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Height="30"
                        Click="CopyReceiverArgumentsButton_Click"
                        Content="Copy args" />
            </Grid>
        </Expander>

        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#DDE2E7"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="10"
                        Background="#F8FAFB">
                    <DockPanel>
                        <TextBlock x:Name="SelectedRecordText"
                                   Margin="4,0,16,0"
                                   VerticalAlignment="Center"
                                   Foreground="#596573"
                                   Text="Select a completed encode" />
                        <WrapPanel HorizontalAlignment="Right">
                        <Button x:Name="PlayDestinationButton"
                                MinWidth="90"
                                Height="30"
                                Margin="0,0,6,0"
                                Click="PlayDestinationButton_Click"
                                Content="Play output"
                                IsEnabled="False" />
                        <Button x:Name="PlaySourceButton"
                                MinWidth="90"
                                Height="30"
                                Margin="0,0,6,0"
                                Click="PlaySourceButton_Click"
                                Content="Play source"
                                IsEnabled="False" />
                        <Button x:Name="RevealDestinationButton"
                                MinWidth="95"
                                Height="30"
                                Margin="0,0,6,0"
                                Click="RevealDestinationButton_Click"
                                Content="Show output"
                                IsEnabled="False" />
                        <Button x:Name="RevealSourceButton"
                                MinWidth="95"
                                Height="30"
                                Margin="0,0,6,0"
                                Click="RevealSourceButton_Click"
                                Content="Show source"
                                IsEnabled="False" />
                        <Button x:Name="CopyDestinationPathButton"
                                MinWidth="105"
                                Height="30"
                                Margin="0,0,6,0"
                                Click="CopyDestinationPathButton_Click"
                                Content="Copy output path"
                                IsEnabled="False" />
                        <Button x:Name="CopySourcePathButton"
                                MinWidth="105"
                                Height="30"
                                Click="CopySourcePathButton_Click"
                                Content="Copy source path"
                                IsEnabled="False" />
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <DataGrid x:Name="HistoryGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding HistoryRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          AlternatingRowBackground="#F8FAFB"
                          SelectionChanged="HistoryGrid_SelectionChanged"
                          MouseDoubleClick="HistoryGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Completed" Binding="{Binding Completed}" Width="155" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="145" />
                        <DataGridTextColumn Header="Source" Binding="{Binding SourceFilename}" Width="*" MinWidth="180" />
                        <DataGridTextColumn Header="Original size" Binding="{Binding SourceSize}" Width="120" />
                        <DataGridTextColumn Header="Converted size" Binding="{Binding DestinationSize}" Width="125" />
                        <DataGridTextColumn Header="Output size" Binding="{Binding OutputPercentage}" Width="105" />
                        <DataGridTextColumn Header="Space saved" Binding="{Binding SpaceSaved}" Width="120" />
                        <DataGridTextColumn Header="Converted file" Binding="{Binding DestinationFilename}" Width="*" MinWidth="180" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="5"
                   Margin="4,10,0,0"
                   Foreground="#596573"
                   Text="Loading history..." />
    </Grid>
</Window>
