<Window x:Class="HandBrakeCompletedManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HandBrake Completed Manager"
        Height="900"
        Width="1400"
        MinHeight="700"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,20" Background="{StaticResource NavyBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="46"
                        Height="46"
                        Margin="0,0,14,0"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="12">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="HC" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="HandBrake Completed Manager" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#AEB9CA"
                               Text="Your verified encode history and safe replacement workspace" />
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button x:Name="RecoveryButton"
                            MinWidth="120"
                            Margin="0,0,8,0"
                            Background="#263650"
                            BorderBrush="#3A4A63"
                            Foreground="White"
                            Click="RecoveryButton_Click"
                            Content="Recovery (0)"
                            IsEnabled="False" />
                    <Button x:Name="SettingsButton"
                            MinWidth="96"
                            Margin="0,0,8,0"
                            Background="#263650"
                            BorderBrush="#3A4A63"
                            Foreground="White"
                            Click="SettingsButton_Click"
                            Content="Settings" />
                    <Button x:Name="RefreshButton"
                            MinWidth="96"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="RefreshButton_Click"
                            Content="Refresh" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="3" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Style="{StaticResource EyebrowStyle}" Text="COMPLETED ENCODES" />
                                <TextBlock x:Name="CompletedCountText"
                                           Margin="0,5,0,0"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Text="0" />
                                <TextBlock Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="Captured permanently" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Margin="8,0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#6172D9" CornerRadius="3" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Style="{StaticResource EyebrowStyle}" Text="ORIGINAL LIBRARY" />
                                <TextBlock x:Name="OriginalSizeText" Margin="0,5,0,0" FontSize="28" FontWeight="SemiBold" Text="0 B" />
                                <TextBlock Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="Before conversion" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Margin="8,0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#2898A8" CornerRadius="3" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Style="{StaticResource EyebrowStyle}" Text="CONVERTED LIBRARY" />
                                <TextBlock x:Name="ConvertedSizeText" Margin="0,5,0,0" FontSize="28" FontWeight="SemiBold" Text="0 B" />
                                <TextBlock Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="After conversion" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource SuccessBrush}" CornerRadius="3" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Style="{StaticResource EyebrowStyle}" Text="STORAGE SAVED" />
                                <TextBlock x:Name="SpaceSavedText" Margin="0,5,0,0" FontSize="28" FontWeight="SemiBold" Text="0 B" />
                                <TextBlock Margin="0,3,0,0" Foreground="{StaticResource SuccessBrush}" Text="Recovered capacity" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Margin="0,0,0,16" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="42" Height="42" Margin="0,0,14,0" Background="{StaticResource SuccessSoftBrush}" CornerRadius="10">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{StaticResource SuccessBrush}"
                                       Text="&#xE968;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="HandBrake connection" />
                            <TextBlock x:Name="ConnectionStatusText" Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="Not checked" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                            <ComboBox x:Name="InstallationComboBox"
                                      AutomationProperties.Name="Detected HandBrake installation"
                                      Width="360"
                                      Margin="0,0,10,0"
                                      ItemsSource="{Binding DetectedInstallations}"
                                      DisplayMemberPath="DisplayLabel"
                                      SelectionChanged="InstallationComboBox_SelectionChanged" />
                            <Button x:Name="FindHandBrakeButton"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Click="FindHandBrakeButton_Click"
                                    Content="Find HandBrake" />
                            <Button x:Name="BrowseHandBrakeButton"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Click="BrowseHandBrakeButton_Click"
                                    Content="Browse" />
                            <Button x:Name="TestConnectionButton"
                                    Style="{StaticResource SoftAccentButtonStyle}"
                                    Click="TestConnectionButton_Click"
                                    Content="Test pipeline"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Expander Grid.Row="2" Margin="0,0,0,16" IsExpanded="False">
                    <Expander.Header>
                        <Border Padding="18,14" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Completion capture setup" />
                                    <TextBlock x:Name="ReceiverStatusText" Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="Checking receiver..." />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           Text="Show setup" />
                            </Grid>
                        </Border>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="95" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       Margin="0,0,0,14"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="In HandBrake, open Tools > Preferences > When Done. Under Encode Completed, enable Send File To, then use the executable and arguments below." />
                            <TextBlock Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Executable" />
                            <TextBox x:Name="ReceiverPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,10,8" IsReadOnly="True" />
                            <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,8" Style="{StaticResource CompactButtonStyle}" Click="CopyReceiverPathButton_Click" Content="Copy path" />
                            <TextBlock Grid.Row="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="Arguments" />
                            <TextBox x:Name="ReceiverArgumentsTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,10,0" IsReadOnly="True" />
                            <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource CompactButtonStyle}" Click="CopyReceiverArgumentsButton_Click" Content="Copy args" />
                        </Grid>
                    </Border>
                </Expander>

                <Border Grid.Row="3" MinHeight="360" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,18,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Completed library" />
                                <TextBlock Margin="0,3,0,0" Style="{StaticResource MutedTextStyle}" Text="Search, inspect, and safely manage completed encodes" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBox x:Name="HistorySearchTextBox"
                                         AutomationProperties.Name="Search completed history"
                                         Width="260"
                                         Margin="0,0,8,0"
                                         ToolTip="Search filenames, paths, extensions, and statuses"
                                         TextChanged="HistorySearchTextBox_TextChanged" />
                                <ComboBox x:Name="QuickFilterComboBox"
                                          AutomationProperties.Name="Completed history quick filter"
                                          Width="190"
                                          Margin="0,0,8,0"
                                          SelectionChanged="QuickFilterComboBox_SelectionChanged">
                                    <ComboBoxItem Tag="All" Content="All records" />
                                    <ComboBoxItem Tag="Today" Content="Today" />
                                    <ComboBoxItem Tag="LastSevenDays" Content="Last 7 days" />
                                    <ComboBoxItem Tag="MissingFiles" Content="Missing files" />
                                    <ComboBoxItem Tag="OutputLargerThanSource" Content="Output larger than source" />
                                </ComboBox>
                                <Button Style="{StaticResource CompactButtonStyle}" Click="ClearHistoryFiltersButton_Click" Content="Clear" />
                                <TextBlock x:Name="ResultsCountText"
                                           Margin="14,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Text="0 shown" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Padding="16,12"
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="0,1,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SelectedRecordText"
                                           Margin="4,0,16,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Text="Select a completed encode" />
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <Button x:Name="ReviewReplacementButton"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="ReviewReplacementButton_Click"
                                            Content="Review &amp; replace"
                                            IsEnabled="False" />
                                    <Button x:Name="PlayDestinationButton" Margin="0,0,6,0" Style="{StaticResource CompactButtonStyle}" Click="PlayDestinationButton_Click" Content="Play output" IsEnabled="False" />
                                    <Button x:Name="PlaySourceButton" Margin="0,0,6,0" Style="{StaticResource CompactButtonStyle}" Click="PlaySourceButton_Click" Content="Play source" IsEnabled="False" />
                                    <Button x:Name="RevealDestinationButton" Margin="0,0,6,0" Style="{StaticResource CompactButtonStyle}" Click="RevealDestinationButton_Click" Content="Show output" IsEnabled="False" />
                                    <Button x:Name="RevealSourceButton" Margin="0,0,6,0" Style="{StaticResource CompactButtonStyle}" Click="RevealSourceButton_Click" Content="Show source" IsEnabled="False" />
                                    <Button x:Name="CopyDestinationPathButton" Margin="0,0,6,0" Style="{StaticResource CompactButtonStyle}" Click="CopyDestinationPathButton_Click" Content="Copy output path" IsEnabled="False" />
                                    <Button x:Name="CopySourcePathButton" Margin="0,0,6,0" Style="{StaticResource CompactButtonStyle}" Click="CopySourcePathButton_Click" Content="Copy source path" IsEnabled="False" />
                                    <Button x:Name="RemoveHistoryButton" Style="{StaticResource DangerButtonStyle}" Click="RemoveHistoryButton_Click" Content="Remove history" IsEnabled="False" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="HistoryGrid"
                                  Grid.Row="2"
                                  ItemsSource="{Binding HistoryRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  SelectionChanged="HistoryGrid_SelectionChanged"
                                  MouseDoubleClick="HistoryGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="COMPLETED" Binding="{Binding Completed}" SortMemberPath="Record.CompletedAtUtc" Width="150" />
                                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" SortMemberPath="Record.CurrentStatus" Width="140" />
                                <DataGridTextColumn Header="SOURCE" Binding="{Binding SourceFilename}" SortMemberPath="Record.SourceFilename" Width="*" MinWidth="170" />
                                <DataGridTextColumn Header="ORIGINAL" Binding="{Binding SourceSize}" SortMemberPath="Record.SourceSize" Width="110" />
                                <DataGridTextColumn Header="CONVERTED" Binding="{Binding DestinationSize}" SortMemberPath="Record.DestinationSize" Width="115" />
                                <DataGridTextColumn Header="OUTPUT SIZE" Binding="{Binding OutputPercentage}" SortMemberPath="Record.OutputPercentage" Width="105" />
                                <DataGridTextColumn Header="SAVED" Binding="{Binding SpaceSaved}" SortMemberPath="Record.SpaceSavedBytes" Width="110" />
                                <DataGridTextColumn Header="CONVERTED FILE" Binding="{Binding DestinationFilename}" SortMemberPath="Record.DestinationFilename" Width="*" MinWidth="170" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border x:Name="DetailsPanel"
                                Grid.Row="3"
                                Padding="18,14"
                                Background="#F8F9FC"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="0,1,0,0"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8" Orientation="Horizontal">
                                    <TextBlock FontWeight="SemiBold" Text="Record details" />
                                    <TextBlock x:Name="DetailsCompletedText" Margin="16,0,0,0" Foreground="{StaticResource InkMutedBrush}" />
                                    <TextBlock x:Name="DetailsStatusText" Margin="16,0,0,0" Foreground="{StaticResource InkMutedBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Style="{StaticResource EyebrowStyle}" Text="SOURCE" />
                                <TextBox x:Name="DetailsSourcePathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" BorderThickness="0" Background="Transparent" IsReadOnly="True" />
                                <TextBlock Grid.Row="2" VerticalAlignment="Center" Style="{StaticResource EyebrowStyle}" Text="OUTPUT" />
                                <TextBox x:Name="DetailsDestinationPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,4" BorderThickness="0" Background="Transparent" IsReadOnly="True" />
                                <TextBlock Grid.Row="3" Style="{StaticResource EyebrowStyle}" Text="METRICS" />
                                <TextBlock x:Name="DetailsMetricsText" Grid.Row="3" Grid.Column="1" Foreground="{StaticResource InkMutedBrush}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="28,11" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource InkMutedBrush}" Text="Loading history..." />
        </Border>
    </Grid>
</Window>
