<Window x:Class="HandBrakeCompletedManager.App.BulkConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm bulk action"
        Width="1040"
        Height="680"
        MinWidth="820"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeadingText" Style="{StaticResource SectionTitleStyle}" FontSize="22" />
            <TextBlock x:Name="DescriptionText"
                       Margin="0,8,0,0"
                       MaxWidth="920"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource InkMutedBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,14"
                Padding="14,11"
                Background="{StaticResource WarningSoftBrush}"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock x:Name="SummaryText" TextWrapping="Wrap" />
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="150" />
                <DataGridTextColumn Header="SOURCE" Binding="{Binding SourcePath}" Width="*" MinWidth="280" />
                <DataGridTextColumn Header="OUTPUT / TARGET" Binding="{Binding TargetPath}" Width="*" MinWidth="280" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="100" Margin="0,0,8,0" IsCancel="True" Content="Cancel" />
            <Button x:Name="SecondaryConfirmButton"
                    MinWidth="220"
                    Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Click="SecondaryConfirmButton_Click" />
            <Button x:Name="ConfirmButton"
                    MinWidth="170"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="ConfirmButton_Click" />
        </StackPanel>
    </Grid>
</Window>
