<Window x:Class="HandBrakeCompletedManager.App.DirectReplacementConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace source"
        Width="760"
        Height="550"
        MinWidth="660"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26,20" Background="{StaticResource NavyBrush}">
            <StackPanel>
                <TextBlock FontSize="23" FontWeight="SemiBold" Foreground="White" Text="Replace the original source?" />
                <TextBlock Margin="0,5,0,0" Foreground="#AEB9CA" Text="Choose whether the separate HandBrake output should remain" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24">
                <Border Padding="15,13"
                        Background="{StaticResource DangerSoftBrush}"
                        BorderBrush="{StaticResource DangerBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" Text="This action cannot be undone" />
                        <TextBlock Margin="0,5,0,0"
                                   TextWrapping="Wrap"
                                   Text="The original source is permanently replaced. No recovery backup or checksum verification is created." />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,20,0,5" Style="{StaticResource EyebrowStyle}" Text="ORIGINAL SOURCE" />
                <TextBox x:Name="SourcePathTextBox" IsReadOnly="True" TextWrapping="Wrap" />
                <TextBlock Margin="0,14,0,5" Style="{StaticResource EyebrowStyle}" Text="ENCODED OUTPUT" />
                <TextBox x:Name="OutputPathTextBox" IsReadOnly="True" TextWrapping="Wrap" />
                <TextBlock Margin="0,14,0,5" Style="{StaticResource EyebrowStyle}" Text="REPLACEMENT LOCATION" />
                <TextBox x:Name="ReplacementPathTextBox" IsReadOnly="True" TextWrapping="Wrap" />

                <TextBlock Margin="0,18,0,0"
                           Foreground="{StaticResource InkMutedBrush}"
                           TextWrapping="Wrap"
                           Text="Replace Source moves the encoded output into the source library and removes the separate output. Replace Source and Keep Output copies it instead. Cross-drive copies show progress and can be cancelled before the original is changed." />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="26,14" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button MinWidth="90" Margin="0,0,8,0" IsCancel="True" Content="Cancel" />
                <Button MinWidth="205" Margin="0,0,8,0" Click="KeepOutputButton_Click" Content="Replace Source and Keep Output" />
                <Button MinWidth="145"
                        IsDefault="True"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="ReplaceButton_Click"
                        Content="Replace Source" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
