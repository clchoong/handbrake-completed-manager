<Window x:Class="HandBrakeCompletedManager.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - HandBrake Completed Manager"
        Width="520"
        Height="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Application settings" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#596573"
                       Text="Settings are stored locally and are not written to HandBrake." />
        </StackPanel>

        <CheckBox x:Name="StartMinimizedCheckBox"
                  Grid.Row="1"
                  Margin="0,0,0,14"
                  Content="Start with the main window hidden in the notification area" />
        <CheckBox x:Name="CloseToTrayCheckBox"
                  Grid.Row="2"
                  Margin="0,0,0,14"
                  Content="Close the main window to the notification area" />
        <CheckBox x:Name="NotificationsEnabledCheckBox"
                  Grid.Row="3"
                  Margin="0,0,0,18"
                  Content="Show notification-area guidance" />

        <StackPanel Grid.Row="4" Margin="0,0,0,18" Orientation="Horizontal">
            <TextBlock Width="180" VerticalAlignment="Center" Text="History refresh interval" />
            <ComboBox x:Name="RefreshIntervalComboBox"
                      Width="130"
                      Height="30"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Tag="3" Content="3 seconds" />
                <ComboBoxItem Tag="5" Content="5 seconds" />
                <ComboBoxItem Tag="10" Content="10 seconds" />
                <ComboBoxItem Tag="30" Content="30 seconds" />
                <ComboBoxItem Tag="60" Content="60 seconds" />
            </ComboBox>
        </StackPanel>

        <Border Grid.Row="5"
                Padding="12"
                Background="White"
                BorderBrush="#DDE2E7"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Diagnostic logs" />
                <TextBox x:Name="LogDirectoryTextBox"
                         Margin="0,8,0,8"
                         Padding="6,4"
                         IsReadOnly="True" />
                <StackPanel Orientation="Horizontal">
                    <Button Width="115"
                            Height="30"
                            Click="OpenLogFolderButton_Click"
                            Content="Open log folder" />
                    <TextBlock x:Name="SettingsStatusText"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#596573" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="6"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="90"
                    Height="34"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Content="Cancel" />
            <Button Width="90"
                    Height="34"
                    IsDefault="True"
                    Click="SaveButton_Click"
                    Content="Save" />
        </StackPanel>
    </Grid>
</Window>
