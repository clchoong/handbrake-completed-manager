<Window x:Class="HandBrakeCompletedManager.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — HandBrake Completed Manager"
        Width="600"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="26,20" Background="{StaticResource NavyBrush}">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="Application settings" />
                <TextBlock Margin="0,4,0,0" Foreground="#AEB9CA" Text="Tune the local desktop experience without changing HandBrake" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="26,22">
            <Border Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="WINDOW &amp; NOTIFICATION AREA" />
                    <CheckBox x:Name="StartMinimizedCheckBox"
                              Margin="0,16,0,14"
                              Content="Start with the main window hidden in the notification area" />
                    <CheckBox x:Name="CloseToTrayCheckBox"
                              Margin="0,0,0,14"
                              Content="Close the main window to the notification area" />
                    <CheckBox x:Name="NotificationsEnabledCheckBox"
                              Content="Show notification-area guidance" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="History refresh" />
                        <TextBlock Margin="0,3,20,0" Style="{StaticResource MutedTextStyle}" Text="How frequently the open library checks for completed encodes" />
                    </StackPanel>
                    <ComboBox x:Name="RefreshIntervalComboBox" Grid.Column="1" Width="140" VerticalAlignment="Center">
                        <ComboBoxItem Tag="3" Content="3 seconds" />
                        <ComboBoxItem Tag="5" Content="5 seconds" />
                        <ComboBoxItem Tag="10" Content="10 seconds" />
                        <ComboBoxItem Tag="30" Content="30 seconds" />
                        <ComboBoxItem Tag="60" Content="60 seconds" />
                    </ComboBox>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Diagnostic logs" />
                    <TextBlock Margin="0,3,0,10" Style="{StaticResource MutedTextStyle}" Text="Local operational records for troubleshooting; no media content is stored" />
                    <TextBox x:Name="LogDirectoryTextBox" Margin="0,0,0,10" IsReadOnly="True" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource CompactButtonStyle}" Click="OpenLogFolderButton_Click" Content="Open log folder" />
                        <TextBlock x:Name="SettingsStatusText" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource InkMutedBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Padding="26,13" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="96" Margin="0,0,8,0" IsCancel="True" Content="Cancel" />
                <Button MinWidth="96" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="SaveButton_Click" Content="Save settings" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
